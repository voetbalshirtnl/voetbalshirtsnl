<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>VoetbalshirtsNL – Oranje WK 2026 Fan Shirts</title>

  <!-- FONTS -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- STYLES -->
  <style>
    :root {
      --bg-main: #020617;             /* heel donker blauw/zwart */
      --bg-elevated: #020617;
      --bg-elevated-soft: #0b1220;
      --bg-accent-soft: rgba(249, 115, 22, 0.12);

      --text-main: #e5e7eb;
      --text-soft: #9ca3af;
      --text-muted: #6b7280;

      --accent: #f97316;              /* oranje */
      --accent-soft: #fed7aa;
      --accent-strong: #ea580c;

      --border-subtle: rgba(148, 163, 184, 0.25);
      --shadow-soft: 0 22px 70px rgba(15, 23, 42, 0.8);

      --radius-lg: 18px;
      --radius-xl: 26px;
      --radius-full: 999px;

      --transition-fast: 0.18s ease-out;
      --transition-med: 0.25s ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top, #020617 0, #020617 40%, #000000 100%);
      color: var(--text-main);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button {
      font-family: inherit;
    }

    /* LAYOUT */

    .page-shell {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      padding: 28px 16px 40px;
    }

    .page-inner {
      width: 100%;
      max-width: 1120px;
    }

    /* Top badge */

    .top-badge-row {
      display: flex;
      justify-content: center;
      margin-bottom: 18px;
    }

    .top-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid rgba(248, 250, 252, 0.18);
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.8));
      box-shadow: 0 14px 40px rgba(15, 23, 42, 0.9);
      backdrop-filter: blur(16px);
    }

    .top-badge-pill {
      background: rgba(249, 115, 22, 0.16);
      color: #fed7aa;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 9px;
      border-radius: 999px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      border: 1px solid rgba(249, 115, 22, 0.6);
    }

    .top-badge-text {
      font-size: 12px;
      color: #cbd5f5;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .top-badge-text-dot {
      width: 5px;
      height: 5px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.25);
    }

    /* Hero layout */

    .hero-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 1.05fr);
      gap: 28px;
      align-items: center;
    }

    @media (max-width: 900px) {
      .hero-shell {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    /* LEFT */

    .hero-left {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .hero-title-block {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .hero-kicker {
      font-size: 13px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #93c5fd;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .hero-kicker-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: linear-gradient(135deg, #f97316, #fb923c);
      box-shadow: 0 0 0 5px rgba(248, 113, 22, 0.35);
    }

    .hero-title {
      font-size: clamp(28px, 4vw, 36px);
      line-height: 1.08;
      letter-spacing: -0.04em;
      color: #f9fafb;
    }

    .hero-title span {
      background: linear-gradient(135deg, #f97316, #fb923c);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-subtitle {
      font-size: 15px;
      line-height: 1.55;
      color: var(--text-soft);
      max-width: 520px;
    }

    .hero-usp-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 6px;
    }

    .hero-usp-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid rgba(148, 163, 184, 0.5);
      font-size: 11px;
      color: #e5e7eb;
    }

    .hero-usp-pill span {
      font-size: 13px;
    }

    .hero-usp-icon-check {
      width: 15px;
      height: 15px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #22c55e, #15803d);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #e5f9ef;
      font-size: 11px;
    }

    /* MAIN CARD */

    .hero-main-card {
      background: radial-gradient(circle at top left, #020617, #020617 35%, #000000 100%);
      border-radius: var(--radius-xl);
      padding: 18px;
      border: 1px solid rgba(148, 163, 184, 0.5);
      box-shadow: var(--shadow-soft);
      position: relative;
      overflow: hidden;
    }

    .hero-main-card::before {
      content: "";
      position: absolute;
      inset: -40%;
      background:
        radial-gradient(circle at 10% 0%, rgba(248, 113, 22, 0.10), transparent 60%),
        radial-gradient(circle at 85% 0%, rgba(56, 189, 248, 0.12), transparent 55%);
      opacity: 0.9;
      pointer-events: none;
    }

    .hero-main-inner {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.15fr);
      gap: 16px;
      align-items: stretch;
    }

    @media (max-width: 800px) {
      .hero-main-inner {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .hero-main-left,
    .hero-main-right {
      position: relative;
      z-index: 1;
    }

    .hero-main-left {
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.95);
      padding: 14px 14px 12px;
      border: 1px solid rgba(148, 163, 184, 0.6);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .hero-info-eyebrow {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #bfdbfe;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .hero-info-eyebrow-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, rgba(129, 140, 248, 0.6), transparent);
    }

    .hero-info-title {
      font-size: 16px;
      font-weight: 600;
      color: #f9fafb;
    }

    .hero-info-body {
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-soft);
    }

    .hero-info-highlight {
      margin-top: 4px;
      padding: 8px 10px;
      border-radius: 12px;
      border: 1px dashed rgba(249, 115, 22, 0.8);
      background: rgba(15, 23, 42, 0.95);
      font-size: 12px;
      color: #fed7aa;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .hero-info-badge {
      padding: 3px 8px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid rgba(251, 146, 60, 0.9);
      font-size: 11px;
      color: #fed7aa;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .hero-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      margin-top: 4px;
    }

    .hero-meta-item {
      font-size: 11px;
      color: var(--text-muted);
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .hero-meta-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #22c55e;
    }

    /* FORM */

    .hero-main-right {
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.96);
      padding: 14px 14px 12px;
      border: 1px solid rgba(148, 163, 184, 0.6);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .form-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-bottom: 4px;
    }

    .form-title {
      font-size: 14px;
      font-weight: 600;
      color: #f9fafb;
    }

    .form-subtitle {
      font-size: 12px;
      color: var(--text-soft);
    }

    .form-secure-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.96);
      border: 1px solid rgba(148, 163, 184, 0.9);
      font-size: 11px;
      color: #e5e7eb;
      white-space: nowrap;
    }

    .form-secure-icon {
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 20%, #22c55e, #16a34a);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #ecfdf3;
      font-size: 10px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 9px;
    }

    .form-row-2 {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 9px;
    }

    @media (max-width: 600px) {
      .form-row-2 {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .form-label {
      font-size: 12px;
      color: #e5e7eb;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .form-label span {
      font-weight: 500;
    }

    .form-label small {
      font-size: 11px;
      color: var(--text-muted);
    }

    .input-shell {
      position: relative;
      display: flex;
      align-items: center;
    }

    .input-prefix {
      position: absolute;
      left: 10px;
      font-size: 12px;
      color: var(--text-muted);
    }

    .form-input,
    .form-select,
    .form-textarea {
      width: 100%;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.8);
      background: rgba(15, 23, 42, 0.98);
      color: #e5e7eb;
      font-size: 13px;
      padding: 9px 11px;
      outline: none;
      transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background-color var(--transition-fast), transform 0.12s ease-out;
      box-shadow: 0 12px 40px rgba(15, 23, 42, 0.85);
    }

    .form-input::placeholder,
    .form-textarea::placeholder {
      color: var(--text-muted);
    }

    .input-with-prefix {
      padding-left: 22px;
    }

    .form-textarea {
      border-radius: 14px;
      resize: vertical;
      min-height: 52px;
    }

    .form-input:focus,
    .form-select:focus,
    .form-textarea:focus {
      border-color: rgba(248, 113, 22, 0.95);
      box-shadow:
        0 0 0 1px rgba(251, 146, 60, 0.85),
        0 20px 50px rgba(15, 23, 42, 1);
      transform: translateY(-1px);
      background: rgba(15, 23, 42, 1);
    }

    .form-actions {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 2px;
    }

    .btn-primary {
      width: 100%;
      border-radius: 999px;
      padding: 10px 14px;
      border: none;
      outline: none;
      cursor: pointer;
      background: linear-gradient(135deg, #f97316, #fb923c);
      color: #111827;
      font-size: 14px;
      font-weight: 600;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      box-shadow:
        0 22px 70px rgba(248, 113, 22, 0.45),
        0 0 0 1px rgba(248, 250, 252, 0.04);
      transition: transform var(--transition-fast), box-shadow var(--transition-fast), background-position 0.2s ease-out;
      background-size: 150%;
      background-position: 0% 50%;
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      background-position: 100% 50%;
      box-shadow:
        0 24px 80px rgba(248, 113, 22, 0.6),
        0 0 0 1px rgba(248, 250, 252, 0.08);
    }

    .btn-primary:active {
      transform: translateY(0);
      box-shadow:
        0 14px 40px rgba(248, 113, 22, 0.45),
        0 0 0 1px rgba(248, 250, 252, 0.08);
    }

    .btn-primary span {
      font-size: 13px;
      letter-spacing: 0.02em;
    }

    .btn-primary-sub {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: #fef3c7;
    }

    .btn-primary-pill {
      padding: 3px 7px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.96);
      color: #fed7aa;
      font-size: 11px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .btn-primary-pill-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: #22c55e;
    }

    .form-trust-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      justify-content: space-between;
    }

    .form-trust-note {
      font-size: 11px;
      color: var(--text-muted);
      max-width: 260px;
    }

    .form-trust-badges {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .trust-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 4px 8px;
      border: 1px solid rgba(148, 163, 184, 0.7);
      background: rgba(15, 23, 42, 0.96);
      font-size: 11px;
      color: #e5e7eb;
    }

    .trust-chip-dot-green {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.35);
    }

    .trust-chip-icon {
      width: 13px;
      height: 13px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.96);
      border: 1px solid rgba(148, 163, 184, 0.8);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      color: #e5e7eb;
    }

    /* RIGHT COLUMN – COMPARISON / INFO */

    .hero-right-shell {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .hero-comparison-card {
      border-radius: 22px;
      background: radial-gradient(circle at top, #020617, #020617 45%, #000000 100%);
      padding: 14px 15px 13px;
      border: 1px solid rgba(148, 163, 184, 0.7);
      box-shadow: 0 20px 70px rgba(15, 23, 42, 0.9);
    }

    .comparison-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .comparison-title-block {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .comparison-label {
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #bfdbfe;
    }

    .comparison-title {
      font-size: 14px;
      font-weight: 600;
      color: #f9fafb;
    }

    .comparison-pill {
      font-size: 11px;
      padding: 4px 9px;
      border-radius: 999px;
      border: 1px solid rgba(251, 146, 60, 0.9);
      background: rgba(15, 23, 42, 0.96);
      color: #fed7aa;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .comparison-pill-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #22c55e;
    }

    .comparison-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 9px;
    }

    @media (max-width: 600px) {
      .comparison-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .comparison-col {
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.96);
      border: 1px solid rgba(148, 163, 184, 0.7);
      padding: 9px 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .comparison-col-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .comparison-col-title {
      font-size: 13px;
      font-weight: 600;
      color: #e5e7eb;
    }

    .comparison-col-price {
      font-size: 12px;
      font-weight: 600;
      color: #f97316;
    }

    .comparison-col-body {
      font-size: 12px;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .comparison-list {
      margin-top: 3px;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .comparison-list li {
      font-size: 11px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .comparison-li-dot {
      width: 4px;
      height: 4px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.9);
    }

    .comparison-highlight-row {
      margin-top: 7px;
      padding-top: 6px;
      border-top: 1px solid rgba(148, 163, 184, 0.4);
      font-size: 11px;
      color: #e5e7eb;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .comparison-highlight-main {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .comparison-highlight-badge {
      padding: 3px 8px;
      border-radius: 999px;
      background: rgba(22, 163, 74, 0.18);
      border: 1px solid rgba(22, 163, 74, 0.85);
      color: #bbf7d0;
      font-size: 11px;
      font-weight: 500;
    }

    .comparison-highlight-secondary {
      font-size: 11px;
      color: var(--text-muted);
    }

    /* EXTRA INFO */

    .hero-extra-card {
      border-radius: 22px;
      background: rgba(15, 23, 42, 0.98);
      border: 1px solid rgba(148, 163, 184, 0.6);
      padding: 12px 14px 11px;
      box-shadow: 0 18px 60px rgba(15, 23, 42, 0.9);
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr);
      gap: 12px;
    }

    @media (max-width: 800px) {
      .hero-extra-card {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .extra-col {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .extra-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: #bfdbfe;
    }

    .extra-title {
      font-size: 13px;
      font-weight: 600;
      color: #f9fafb;
    }

    .extra-text {
      font-size: 12px;
      color: var(--text-soft);
      line-height: 1.55;
    }

    .extra-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 3px;
      margin-top: 2px;
    }

    .extra-list li {
      font-size: 11px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .extra-li-dot {
      width: 4px;
      height: 4px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.9);
    }

    .extra-highlight {
      margin-top: 3px;
      font-size: 11px;
      color: #f97316;
    }

    /* FOOTER */

    .page-footer {
      margin-top: 22px;
      font-size: 11px;
      color: var(--text-muted);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
      border-top: 1px solid rgba(148, 163, 184, 0.45);
      padding-top: 10px;
    }

    .page-footer-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .page-footer a {
      font-size: 11px;
      color: #9ca3af;
    }

    .page-footer a:hover {
      color: #e5e7eb;
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <div class="page-inner">
      <!-- TOP BADGE -->
      <div class="top-badge-row">
        <div class="top-badge">
          <div class="top-badge-pill">Pre‑order Oranje fan‑shirt</div>
          <div class="top-badge-text">
            <span class="top-badge-text-dot"></span>
            Nieuwe levering verwacht vóór start WK 2026
          </div>
        </div>
      </div>

      <!-- HERO -->
      <div class="hero-shell">
        <!-- LEFT -->
        <div class="hero-left">
          <div class="hero-title-block">
            <div class="hero-kicker">
              <span class="hero-kicker-dot"></span>
