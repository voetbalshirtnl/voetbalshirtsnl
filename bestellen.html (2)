  <!-- ✅ SEO: Open Graph (Facebook, WhatsApp preview) -->
  <meta property="og:type" content="website"/>
  <meta property="og:title" content="Pre-order Oranje Fan-shirt 2026 | VoetbalshirtsNL"/>
