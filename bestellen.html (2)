  <!-- ✅ SEO: Twitter Card -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="Pre-order Oranje Fan-shirt 2026 | VoetbalshirtsNL"/>
  <meta name="twitter:description" content="Fan-versie Oranje shirts 2026 voor €24,99. Bestel eenvoudig online."/>
  <meta name="twitter:image" content="https://www.voetbalshirtsnl.nl/oranje-shirt.jpg"/>

  <!-- ✅ SEO: Structured Data – Product + BreadcrumbList -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.voetbalshirtsnl.nl/" },
          { "@type": "ListItem", "position": 2, "name": "Pre-order", "item": "https://www.voetbalshirtsnl.nl/bestellen.html" }
        ]
      },
      {
        "@type": "Product",
        "name": "Fan-versie Oranje thuisshirt 2026",
        "image": "https://www.voetbalshirtsnl.nl/oranje-shirt.jpg",
        "description": "Officieel fan-versie thuisshirt van het Nederlands elftal 2026. Beschikbaar in maat S t/m XL.",
        "brand": { "@type": "Brand", "name": "VoetbalshirtsNL" },
        "offers": {
          "@type": "Offer",
          "priceCurrency": "EUR",
          "price": "24.99",
          "availability": "https://schema.org/PreOrder",
          "url": "https://www.voetbalshirtsnl.nl/bestellen.html"
        }
      }
    ]
  }
  </script>

  <!-- ✅ Performance: Preconnect voor Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --oranje: #FF5500;
      --oranje-donker: #cc4400;
      --zwart: #0a0a0a;
      --wit: #ffffff;
      --achtergrond: #fff5ec;
      --kaart-rand: #e5e2dc;
      --tekst: #1a1a1a;
    }

    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

    body {
      font-family:'Barlow',sans-serif;
      background:var(--achtergrond);
      color:var(--tekst);
      scroll-behavior:smooth;
    }

    /* NAV */
    nav {
      position:fixed; top:0; left:0; right:0; height:68px;
      display:flex; align-items:center; justify-content:space-between;
      padding:0 32px;
      background:rgba(255,255,255,0.96);
      border-bottom:1px solid #eee;
      z-index:100;
    }
    .logo {
      font-family:'Barlow Condensed',sans-serif;
      font-weight:900; font-size:1.6rem;
      letter-spacing:-0.5px; text-decoration:none; color:var(--zwart);
    }
    .logo span { color:var(--oranje); }

    .nav-links {
      list-style:none;
      display:flex;
      gap:28px;
    }
    .nav-links a {
      font-size:0.875rem;
      font-weight:600;
      letter-spacing:0.06em;
      text-transform:uppercase;
      text-decoration:none;
      color:var(--tekst);
      transition: color 0.2s;
    }
    .nav-links a:hover { color:var(--oranje); }

    /* ✅ Mobiel hamburger menu */
    .nav-toggle {
      display:none;
      flex-direction:column;
      gap:5px;
      background:none;
      border:none;
      cursor:pointer;
      padding:4px;
    }
    .nav-toggle span {
      display:block;
      width:24px; height:2px;
      background:var(--zwart);
      transition: all 0.2s;
    }

    main {
      padding:96px 16px 32px;
    }

    .bestel-container { max-width:960px; margin:0 auto; }

    /* ✅ SEO: Breadcrumb zichtbaar -->*/
    .breadcrumb {
      font-size:0.8rem;
      color:#999;
      margin-bottom:14px;
    }
    .breadcrumb a { color:#999; text-decoration:none; }
    .breadcrumb a:hover { color:var(--oranje); }
    .breadcrumb span { margin:0 6px; }

    .badge {
      display:inline-block;
      font-family:'Barlow Condensed',sans-serif;
      font-size:0.75rem; font-weight:700;
      letter-spacing:0.18em; text-transform:uppercase;
      color:var(--oranje);
      border:1.5px solid var(--oranje);
      padding:5px 14px;
      margin-bottom:18px;
    }

    h1 {
      font-family:'Barlow Condensed',sans-serif;
      font-weight:900; font-size:2.3rem;
      text-transform:uppercase; letter-spacing:-0.5px;
      margin-bottom:8px;
    }
    h1 span { color:var(--oranje); }

    .intro {
      font-size:0.98rem;
      color:#555;
      margin:0 0 20px;
      max-width:540px;
      line-height:1.6;
    }

    /* SHIRT KAARTEN */
    .shirts-grid {
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:20px;
      margin:0 0 30px;
    }
    .shirt-card {
      background:var(--wit);
      border-radius:12px;
      border:1px solid var(--kaart-rand);
      padding:12px 12px 14px;
      box-shadow:0 10px 26px rgba(0,0,0,0.05);
      cursor:pointer;
      transition:transform 0.12s ease, box-shadow 0.12s ease;
    }
    .shirt-card:hover {
      transform:translateY(-3px);
      box-shadow:0 16px 40px rgba(0,0,0,0.08);
    }
    .shirt-card:focus-visible {
      outline: 2px solid var(--oranje);
      outline-offset: 3px;
    }
    .shirt-card img {
      width:100%;
      height:240px;
      /* ✅ Performance: expliciet width/height voorkomt layout shift */
      aspect-ratio: 1 / 1;
      object-fit:contain;
      border-radius:10px;
      margin-bottom:8px;
      display:block;
      background:#ffffff;
      /* ✅ Performance: lazy load afbeeldingen */
      loading:lazy;
    }
    .shirt-title {
      font-family:'Barlow Condensed',sans-serif;
      font-weight:700;
      font-size:1.15rem;
      text-transform:uppercase;
      margin-bottom:4px;
    }
    .shirt-meta {
      font-size:0.85rem;
      color:#777;
      margin-bottom:4px;
    }
    .shirt-price {
      font-weight:700;
      font-size:0.9rem;
      color: var(--oranje);
    }

    /* FORMULIER */
    .form-wrapper {
      max-width:640px;
      margin:0 auto;
    }

    .bestel-card {
      background:var(--wit);
      border-radius:12px;
      border:1px solid var(--kaart-rand);
      padding:22px 22px 20px;
      box-shadow:0 16px 40px rgba(0,0,0,0.06);
    }

    .bestel-card-title {
      font-family:'Barlow Condensed',sans-serif;
      font-weight:700; font-size:1.05rem;
      letter-spacing:0.08em; text-transform:uppercase;
      margin-bottom:12px; color:#222;
    }

    .form-row { display:flex; flex-direction:column; gap:4px; margin-bottom:9px; }
    .form-label { font-size:0.8rem; color:#444; font-weight:600; }

    .form-input, .form-select {
      width:100%;
      padding:8px 10px;
      border-radius:6px;
      border:1.5px solid #d6d3ce;
      font-size:0.9rem;
      font-family:'Barlow',sans-serif;
      transition: border-color 0.2s;
    }
    .form-input:focus, .form-select:focus {
      outline:none;
      border-color: var(--oranje);
      box-shadow: 0 0 0 3px rgba(255,85,0,0.12);
    }

    /* ✅ Validatiefeedback */
    .form-input:invalid:not(:placeholder-shown) {
      border-color: #e53e3e;
    }

    .form-help { font-size:0.78rem; color:#777; margin-top:4px; line-height:1.5; }

    button[type="submit"] {
      margin-top:12px;
      width:100%;
      text-align:center;
      background:var(--oranje); color:var(--wit);
      font-family:'Barlow Condensed',sans-serif;
      font-weight:700; font-size:0.95rem;
      letter-spacing:0.08em; text-transform:uppercase;
      border:none; padding:11px 22px;
      cursor:pointer;
      clip-path:polygon(0 0, calc(100% - 10px) 0, 100% 100%, 10px 100%);
      transition: background 0.2s;
    }
    button[type="submit"]:hover { background:var(--oranje-donker); }
    button[type="submit"]:disabled { background:#ccc; cursor:not-allowed; }

    .whatsapp-link {
      display:flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      margin-top:12px;
      text-align:center;
      font-size:0.85rem;
      color:#1f7a34;
      text-decoration:none;
      font-weight:600;
    }
    .whatsapp-link:hover { text-decoration:underline; }

    /* ✅ Betere succes/fout feedback */
    .form-status {
      font-size:0.85rem;
      margin-top:10px;
      min-height:1.4em;
      text-align:center;
      padding:8px 12px;
      border-radius:6px;
      display:none;
    }
    .form-status.succes {
      display:block;
      background:#f0fff4;
      color:#276749;
      border:1px solid #9ae6b4;
    }
    .form-status.fout {
      display:block;
      background:#fff5f5;
      color:#c53030;
      border:1px solid #feb2b2;
    }
    .form-status.laden {
      display:block;
      background:#fffbeb;
      color:#744210;
      border:1px solid #fbd38d;
    }

    /* ✅ Mobiele nav */
    @media(max-width:768px){
      nav { padding:0 20px; }
      .nav-links {
        display:none;
        position:fixed;
        top:68px; left:0; right:0;
        background:#fff;
        flex-direction:column;
        gap:0;
        border-bottom:1px solid #eee;
        box-shadow:0 8px 20px rgba(0,0,0,0.08);
      }
      .nav-links.open { display:flex; }
      .nav-links a {
        padding:14px 24px;
        border-bottom:1px solid #f0f0f0;
        display:block;
      }
      .nav-toggle { display:flex; }
      main { padding:86px 16px 32px; }
      .bestel-container { max-width:100%; }
    }
  </style>
</head>
<body>

  <nav aria-label="Hoofdnavigatie">
    <a class="logo" href="index.html" aria-label="VoetbalshirtsNL – naar homepage">VOETBALSHIRTS<span>NL</span></a>
    <!-- ✅ Toegankelijkheid: hamburger menu op mobiel -->
    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Menu openen">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="nav-menu" role="list">
      <li><a href="index.html#shirts">Shirts</a></li>
      <li><a href="bestellen.html" aria-current="page">Pre-order</a></li>
      <li><a href="gripsokken.html">Gripsokken</a></li>
      <li><a href="over-ons.html">Over ons</a></li>
    </ul>
  </nav>

  <main>
    <div class="bestel-container">

      <!-- ✅ SEO: Zichtbare breadcrumb -->
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="index.html">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Pre-order</span>
      </nav>

      <div class="badge" aria-label="Status: Pre-order">Pre-order</div>
      <!-- ✅ SEO: H1 bevat primaire zoekterm -->
      <h1>Pre-order jouw <span>fan-versie shirt 2026</span></h1>
      <p class="intro">
        Kies hieronder je shirt. Klik op het shirt dat je wilt pre-orderen; het formulier wordt automatisch ingevuld.
      </p>

      <!-- SHIRT-KAARTEN -->
      <section aria-label="Beschikbare shirts" class="shirts-grid">
        <article class="shirt-card" data-shirt="Fan-versie thuisshirt 2026" role="button" tabindex="0" aria-label="Selecteer Oranje thuisshirt 2026 voor €24,99">
          <!-- ✅ Performance: width/height + loading=lazy -->
          <img src="oranje-shirt.jpg" alt="Oranje fan-versie thuisshirt Nederlands elftal 2026" width="400" height="400" loading="lazy">
          <h2 class="shirt-title">Oranje thuisshirt 2026</h2>
          <p class="shirt-meta">Thuis · Oranje · Maat S t/m XL</p>
          <p class="shirt-price">€24,99 per stuk</p>
        </article>

        <article class="shirt-card" data-shirt="Fan-versie uitshirt 2026" role="button" tabindex="0" aria-label="Selecteer Wit uitshirt 2026 voor €24,99">
          <img src="wit-shirt.jpg" alt="Wit fan-versie uitshirt Nederlands elftal 2026" width="400" height="400" loading="lazy">
          <h2 class="shirt-title">Wit uitshirt 2026</h2>
          <p class="shirt-meta">Uit · Wit · Maat S t/m XL</p>
          <p class="shirt-price">€24,99 per stuk</p>
        </article>
      </section>

      <!-- PRE-ORDER FORMULIER -->
      <div class="form-wrapper" id="bestel-form-blok">
        <div class="bestel-card">
          <div class="bestel-card-title" id="form-titel">Pre-order formulier</div>

          <!-- ✅ Toegankelijkheid: aria-labelledby koppelt titel aan formulier -->
          <form id="bestel-form" method="POST" action="https://formspree.io/f/xbdpjozq" novalidate aria-labelledby="form-titel">
            <input type="hidden" name="_subject" value="Nieuwe pre-order shirt via website">

            <div class="form-row">
              <label for="naam" class="form-label">Naam <span aria-hidden="true">*</span></label>
              <input id="naam" name="naam" type="text" required class="form-input" placeholder="Voor- en achternaam" autocomplete="name">
            </div>

            <div class="form-row">
              <label for="email" class="form-label">E-mailadres <span aria-hidden="true">*</span></label>
              <input id="email" name="email" type="email" required class="form-input" placeholder="jij@example.nl" autocomplete="email">
            </div>

            <div class="form-row">
              <label for="adres" class="form-label">Adres <span aria-hidden="true">*</span></label>
              <input id="adres" name="adres" type="text" required class="form-input" placeholder="Straat + huisnummer" autocomplete="street-address">
            </div>

            <div class="form-row">
              <label for="postcode" class="form-label">Postcode + woonplaats <span aria-hidden="true">*</span></label>
              <input id="postcode" name="postcode" type="text" required class="form-input" placeholder="Bijv. 1234AB Amsterdam" autocomplete="postal-code">
            </div>

            <div class="form-row">
              <label for="maat" class="form-label">Maat <span aria-hidden="true">*</span></label>
              <!-- ✅ UX: dropdown i.p.v. vrij tekstveld voorkomt typefouten -->
              <select id="maat" name="maat" required class="form-select">
                <option value="" disabled selected>Kies je maat</option>
                <option value="S">S</option>
                <option value="M">M</option>
                <option value="L">L</option>
                <option value="XL">XL</option>
              </select>
            </div>

            <div class="form-row">
              <label for="shirt" class="form-label">Shirt <span aria-hidden="true">*</span></label>
              <select id="shirt" name="shirt" required class="form-select">
                <option value="Fan-versie thuisshirt 2026">Fan-versie thuisshirt 2026</option>
                <option value="Fan-versie uitshirt 2026">Fan-versie uitshirt 2026</option>
              </select>
            </div>

            <p class="form-help">
              Velden met * zijn verplicht. Je ontvangt een bevestiging op je e-mailadres zodra je bestelling is verwerkt.
            </p>

            <button type="submit" id="submit-btn">
              Verstuur pre-order
            </button>

            <a id="whatsapp-link" class="whatsapp-link" href="#" target="_blank" rel="noopener noreferrer" aria-label="Pre-order versturen via WhatsApp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Of open WhatsApp met je pre-order
            </a>

            <!-- ✅ Verbeterde status feedback -->
            <div id="form-status" class="form-status" role="alert" aria-live="polite"></div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Mobiel menu
    const navToggle = document.querySelector('.nav-toggle');
    const navMenu = document.getElementById('nav-menu');
    navToggle.addEventListener('click', () => {
      const open = navMenu.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', open);
    });

    const bestelForm = document.getElementById('bestel-form');
    const bestelStatus = document.getElementById('form-status');
    const whatsappLink = document.getElementById('whatsapp-link');
    const shirtSelect = document.getElementById('shirt');
    const formBlock = document.getElementById('bestel-form-blok');
    const submitBtn = document.getElementById('submit-btn');

    // Klik op kaart -> juiste shirt selecteren + scrollen
    document.querySelectorAll('.shirt-card').forEach(card => {
      const activate = () => {
        const value = card.getAttribute('data-shirt');
        if (value) shirtSelect.value = value;
        formBlock.scrollIntoView({ behavior:'smooth', block:'start' });
      };
      card.addEventListener('click', activate);
      // ✅ Toegankelijkheid: ook via toetsenbord activeerbaar
      card.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
      });
    });

    function buildWhatsAppUrl() {
      const naam     = document.getElementById('naam').value.trim();
      const email    = document.getElementById('email').value.trim();
      const adres    = document.getElementById('adres').value.trim();
      const postcode = document.getElementById('postcode').value.trim();
      const maat     = document.getElementById('maat').value;
      const shirt    = document.getElementById('shirt').value;
      const phone    = '31630576584';
      const text =
        'Pre-order fan-versie shirt:%0A%0A' +
        'Naam: ' + encodeURIComponent(naam) + '%0A' +
        'E-mailadres: ' + encodeURIComponent(email) + '%0A' +
        'Adres: ' + encodeURIComponent(adres) + '%0A' +
        'Postcode + woonplaats: ' + encodeURIComponent(postcode) + '%0A' +
        'Maat: ' + encodeURIComponent(maat) + '%0A' +
        'Shirt: ' + encodeURIComponent(shirt);
      return 'https://wa.me/' + phone + '?text=' + text;
    }

    whatsappLink.addEventListener('click', function(e) {
      e.preventDefault();
      window.open(buildWhatsAppUrl(), '_blank');
    });

    // ✅ Verbeterde form submit met succes/fout feedback
    bestelForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      submitBtn.disabled = true;
      bestelStatus.className = 'form-status laden';
      bestelStatus.textContent = 'Pre-order wordt verstuurd…';

      try {
        const response = await fetch(bestelForm.action, {
          method: 'POST',
          body: new FormData(bestelForm),
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          bestelStatus.className = 'form-status succes';
          bestelStatus.textContent = '✓ Gelukt! Je pre-order is verstuurd. Je ontvangt een bevestiging per e-mail.';
          bestelForm.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        bestelStatus.className = 'form-status fout';
        bestelStatus.textContent = '✕ Er ging iets mis. Probeer het opnieuw of stuur je bestelling via WhatsApp.';
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>

</body>
