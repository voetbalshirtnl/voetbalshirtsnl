<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- ✅ SEO: Title geoptimaliseerd met keyword + merk -->
  <title>Pre-order Oranje Fan-versie Shirt 2026 | VoetbalshirtsNL</title>

  <!-- ✅ SEO: Meta description -->
